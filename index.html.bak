<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CEO Briefing — Mar 14, 2026 (Evening)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    @font-face {
      font-family: 'Copernicus Trial';
      src: url('fonts/CopernicusTrial-Book.ttf') format('truetype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Copernicus Trial';
      src: url('fonts/CopernicusTrial-Medium.ttf') format('truetype');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #F9F9F9;
      --surface: #FFFFFF;
      --bg-secondary: #FDFDFD;
      --bg-tertiary: #F7F6F4;
      --bg-hover: #F5F4F3;
      --bg-hover-darker: #ECEAE7;
      --bg-accent: #2A8F87;
      --bg-accent-dark: #1D736C;
      --text: #111111;
      --text-secondary: #44403C;
      --text-muted: #78716C;
      --text-link: #1D736C;
      --text-link-hover: #2A8F87;
      --text-error: #C5624E;
      --border: #E8E5E1;
      --border-default: #D5D2CD;
      --border-accent: #B56AEB;
      --serif: 'Copernicus Trial', Georgia, serif;
      --sans: 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
      --shadow-sm: 0 4px 8px rgba(0,0,0,0.04), 0 2px 4px rgba(0,0,0,0.06);
      --shadow-md: 0 8px 16px rgba(0,0,0,0.06), 0 4px 8px rgba(0,0,0,0.04);
      --shadow-lg: 0 16px 32px rgba(0,0,0,0.08);
      --radius: 24px;
      --green: #2A8F87;
      --red: #B94A48;
    }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background: var(--bg);
      color: var(--text);
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .masthead {
      background: transparent;
      border-bottom: none;
      padding: 0;
      position: relative;
    }

    .masthead-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 2rem;
      text-align: center;
    }

    .masthead .overline {
      font-family: var(--sans);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }

    .masthead h1 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 400;
      line-height: 1.2;
      color: var(--text);
      margin-bottom: 0.5rem;
    }

    .masthead .edition-date {
      font-family: var(--sans);
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-secondary);
      margin-bottom: 0.25rem;
    }

    .masthead .edition-sub {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .divider-bar {
      width: 60px;
      height: 3px;
      background: var(--text);
      margin: 1rem auto 0;
      border-radius: 2px;
    }

    .nav-bar {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0;
      background: var(--bg-secondary);
      border-bottom: none;
      font-family: var(--sans);
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    .nav-bar a {
      text-decoration: none;
      color: var(--text-muted);
      padding: 0.7rem 1.5rem;
      margin: 4px 0;
      border-radius: 999px;
      transition: color 0.2s ease, background 0.2s ease;
    }

    .nav-bar a.active {
      color: var(--text-primary);
      background: #ECEAE7;
    }

    .nav-bar a:hover:not(.active) {
      color: var(--text-secondary);
    }

    .lang-toggle {
      position: absolute;
      top: 0.75rem;
      right: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-family: var(--sans);
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.04em;
    }

    .lang-toggle a {
      text-decoration: none;
      color: var(--text-muted);
      transition: color 0.2s ease;
    }

    .lang-toggle a.active {
      color: var(--text);
    }

    .lang-toggle a:hover:not(.active) {
      color: var(--text-secondary);
    }

    .lang-toggle .sep {
      color: var(--border);
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }

    .section {
      margin-bottom: 3.5rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid var(--text);
      padding-bottom: 0.75rem;
    }

    .section-icon {
      font-size: 1.5rem;
    }

    .section-title {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 500;
      letter-spacing: -0.02em;
    }

    .cards {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      transition: box-shadow 0.2s ease;
    }

    .card:hover {
      box-shadow: var(--shadow-sm);
    }

    .card.featured {
      border-left: 3px solid var(--bg-accent);
    }

    .card.featured.japan {
      border-left: 3px solid #C53030;
    }

    .card-tag {
      display: inline-block;
      font-family: var(--sans);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
      text-transform: uppercase;
    }

    .card-tag.japan {
      color: #C53030;
    }

    .card-headline {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 500;
      line-height: 1.35;
      color: var(--text);
      margin-bottom: 0.75rem;
    }

    .card-body {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--text-secondary);
    }

    .card-sources {
      margin-top: 0.75rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .source-link {
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--text-link);
      text-decoration: none;
      padding: 0.15rem 0.5rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      transition: all 0.2s;
    }

    .source-link:hover {
      border-color: var(--text-link);
      background: var(--bg-tertiary);
    }

    .src-arrow { font-size: 0.6rem; }

    .stat {
      font-weight: 600;
      color: var(--text);
    }

    .tap-hint {
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
      font-style: italic;
    }

    .collapsible .card-body,
    .collapsible .card-sources {
      display: none;
    }

    .collapsible.expanded .card-body,
    .collapsible.expanded .card-sources {
      display: block;
    }

    .collapsible.expanded .tap-hint {
      display: none;
    }

    .collapsible {
      cursor: pointer;
    }

    .nav-pills {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem 1.5rem;
      flex-wrap: wrap;
    }

    .nav-pill {
      font-family: var(--sans);
      font-size: 0.75rem;
      font-weight: 500;
      text-decoration: none;
      color: var(--text-muted);
      padding: 0.35rem 0.85rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      transition: all 0.2s;
    }

    .nav-pill:hover {
      border-color: var(--text-secondary);
      color: var(--text-secondary);
    }

    .index-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.8rem;
      margin-top: 0.5rem;
    }

    .index-table th {
      font-weight: 600;
      text-align: left;
      padding: 0.5rem 0.75rem;
      border-bottom: 2px solid var(--border);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
    }

    .index-table td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid var(--border);
    }

    .idx-name { font-weight: 500; }
    .idx-level { font-weight: 600; }
    .chg-pos { color: var(--green); font-weight: 600; }
    .chg-neg { color: var(--red); font-weight: 600; }

    .health-gauge-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1.5rem 0;
    }

    .health-gauge {
      position: relative;
      width: 200px;
      height: 100px;
      overflow: hidden;
    }

    .gauge-bg {
      position: absolute;
      width: 200px;
      height: 200px;
      border-radius: 50%;
      background: conic-gradient(
        from 180deg,
        #e74c3c 0deg,
        #e67e22 45deg,
        #f1c40f 90deg,
        #2ecc71 135deg,
        #27ae60 180deg
      );
      mask: radial-gradient(circle at center, transparent 60px, black 61px);
      -webkit-mask: radial-gradient(circle at center, transparent 60px, black 61px);
    }

    .gauge-needle {
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 3px;
      height: 80px;
      background: var(--text);
      transform-origin: bottom center;
      transform: rotate(-90deg);
      transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1);
      border-radius: 2px;
    }

    .gauge-dot {
      position: absolute;
      bottom: -5px;
      left: 50%;
      transform: translateX(-50%);
      width: 12px;
      height: 12px;
      background: var(--text);
      border-radius: 50%;
    }

    .gauge-scale {
      display: flex;
      justify-content: space-between;
      width: 200px;
      font-size: 0.7rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
    }

    .gauge-score {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--text);
      margin-top: 0.5rem;
    }

    .gauge-score-label {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--red);
    }

    .indicator-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .indicator-item {
      text-align: center;
    }

    .indicator-value {
      font-size: 1.25rem;
      font-weight: 700;
    }

    .indicator-name {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    .indicator-sub {
      font-size: 0.65rem;
      color: var(--text-muted);
    }

    .bottom-line {
      background: var(--text);
      color: #f5f5f5;
      border-radius: var(--radius);
      padding: 2rem;
    }

    .bottom-line h3 {
      font-family: var(--serif);
      font-size: 1.3rem;
      margin-bottom: 1rem;
    }

    .bottom-line p {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #d4d4d4;
    }

    .footer {
      text-align: center;
      padding: 2rem 1.5rem;
      font-size: 0.75rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border);
    }

    @media (max-width: 640px) {
      .cards-grid { grid-template-columns: 1fr; }
      .card { border-radius: 0; border-left: none; border-right: none; border-top: none; border-bottom: 1px solid var(--border); box-shadow: none; }
      .card.featured { border-left: none; border-bottom: 2px solid var(--bg-accent); }
      .card.featured.japan { border-left: none; border-bottom: 2px solid #C53030; }
      .indicator-grid { grid-template-columns: repeat(2, 1fr); }
      .bottom-line { border-radius: 0; }
      .nav-pills { display: none; }
      .bottom-line { background: #333; }
      .index-table { font-size: 0.7rem; }
      .index-table td, .index-table th { padding: 0.4rem 0.5rem; }
    }

    @media (max-width: 480px) {
      .masthead-inner { padding: 1.5rem 1rem 1.5rem; }
      .container { padding: 1.5rem 1rem 3rem; }
      .nav-pills {
        justify-content: flex-start;
        overflow-x: auto;
      }
      .bottom-line {
        padding: 1.5rem;
      }
    }
  </style>
</head>
<body>

